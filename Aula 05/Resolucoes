//7
let inicio = 1
let fim = 10

var total = 0
var pares = 0
var impares = 0
var soma = 0

for i in inicio...fim {
    total += 1
    soma += i
    
    if i % 2 == 0 {
        pares += 1
    } else {
        impares += 1
    }
}

let media = Double(soma) / Double(total)

print("Quantidade total: \(total)")
print("Pares: \(pares)")
print("Ímpares: \(impares)")
print("Média: \(media)")

