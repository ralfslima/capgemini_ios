//9
let nomes = ["Ana", "Carlos", "Pedro", "Marina", "João"]
let vogais = "aeiouAEIOU"

for nome in nomes {
    var qtdVogais = 0
    var qtdConsoantes = 0
    
    for letra in nome {
        if vogais.contains(letra) {
            qtdVogais += 1
        } else {
            qtdConsoantes += 1
        }
    }
    
    print("\(nome): Vogais = \(qtdVogais), Consoantes = \(qtdConsoantes)")
}
